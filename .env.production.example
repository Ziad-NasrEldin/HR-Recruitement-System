# ─── Database ────────────────────────────────────────────────────────────────
# Must match the postgres service credentials in docker-compose.yml
DATABASE_URL="postgresql://hr_user:CHANGE_ME_DB_PASS@postgres:5432/hr_recruitment"

# Used by docker-compose to set the postgres container password
POSTGRES_PASSWORD="CHANGE_ME_DB_PASS"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
AUTH_URL="https://hr.mavoid.com"
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_RUN_OPENSSL_RAND_BASE64_32"

# ─── OpenAI (Phase 6: voice assessment — Whisper transcription + GPT-4o scoring) ──
OPENAI_API_KEY="sk-..."

# ─── Gemini (Phase 7: Facebook post generator) ────────────────────────────────
GEMINI_API_KEY="AIza..."

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
# Used only on first run / when you manually run: docker compose exec app npx prisma db seed
SUPER_ADMIN_EMAIL="ziad@example.com"
SUPER_ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASS"
SUPER_ADMIN_NAME="Ziad"

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
